      "post": {
        "tags": ["blog-controller"],
        "summary": "Create blog",
        "description": "Creates a new blog document with schemaVersion=1, stores title/description/content/topics/FAQs from the request,\nsets status to UNPUBLISHED, and initializes lastModifiedAt with the current timestamp.\nAfter a successful save, a matching metadata record is also created for the same slug.\nIf the slug already exists, the operation fails with conflict. If MongoDB schema validation fails, the operation fails with bad request.\n",
        "operationId": "createBlog",
        "parameters": [
          {
            "name": "X-API-Version",
            "in": "header",
            "schema": {
              "type": "string",
              "default": "1.0.0",
              "enum": ["1"]
            }
          }
        ],
        "requestBody": {
          "description": "Blog payload to create",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BlogRequest"
              },
              "examples": {
                "createBlog": {
                  "description": "createBlog",
                  "value": {
                    "slug": "my-first-blog",
                    "title": "My First Blog",
                    "description": "Short description for the blog",
                    "topics": ["spring", "api"],
                    "faqs": [
                      {
                        "question": "What is this?",
                        "answer": "A demo blog."
                      }
                    ],
                    "content": "## Hello world"
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Blog created"
          },
          "400": {
            "description": "Validation failed",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ExceptionResponse"
                },
                "examples": {
                  "validationError": {
                    "description": "validationError",
                    "value": {
                      "message": "Slug is a required field!"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ExceptionResponse"
                },
                "examples": {
                  "unauthorized": {
                    "description": "unauthorized",
                    "value": {
                      "message": "Invalid username or password provided"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ExceptionResponse"
                },
                "examples": {
                  "notFound": {
                    "description": "notFound",
                    "value": {
                      "message": "Slug not found!"
                    }
                  }
                }
              }
            }
          },
          "409": {
            "description": "Slug already exists",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ExceptionResponse"
                },
                "examples": {
                  "conflict": {
                    "description": "conflict",
                    "value": {
                      "message": "Slug already exists in the database"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": ["auth-controller"],
        "summary": "Login",
        "description": "Authenticates credentials by loading the user by username and verifying the submitted password against the stored encoded password.\nIf username is unknown or password does not match, the operation fails with unauthorized.\nOn success, a new token is issued for the username and returned to the client.\n",
        "operationId": "login",
        "parameters": [
          {
            "name": "X-API-Version",
            "in": "header",
