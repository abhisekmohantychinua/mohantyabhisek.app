      "patch": {
        "tags": ["blog-controller"],
        "summary": "Update blog",
        "description": "Partially updates an existing blog by slug.\nOnly non-null and non-blank fields are applied (topics/FAQs are applied only when non-empty), and FAQs are remapped from request DTOs to entity objects.\nWhen at least one field changes, lastModifiedAt is refreshed and the blog is persisted.\nIf no effective fields are provided, this operation is a no-op and returns success without persisting.\nIf the slug is missing, it fails with not found; if schema validation fails on save, it fails with bad request.\n",
        "operationId": "updateBlog",
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "description": "Blog slug",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "my-first-blog"
          },
          {
            "name": "X-API-Version",
            "in": "header",
            "schema": {
              "type": "string",
              "default": "1.0.0",
              "enum": ["1"]
            }
          }
        ],
        "requestBody": {
          "description": "Blog fields to update",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BlogUpdateRequest"
              },
              "examples": {
                "updateBlog": {
                  "description": "updateBlog",
                  "value": {
                    "title": "Updated title",
                    "description": "Updated description",
                    "topics": ["spring"],
                    "faqs": [
                      {
                        "question": "Updated?",
                        "answer": "Yes."
                      }
                    ],
                    "content": "## Updated content"
                  }
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Blog updated"
          },
          "400": {
