  "paths": {
    "/api/blogs": {
      "get": {
        "tags": ["blog-controller"],
        "summary": "List blogs",
        "description": "Returns blogs whose slug contains the optional query value (case-insensitive).\nWhen query is omitted, all slugs are matched.\nIf status is provided, only blogs in that status are returned; otherwise all statuses are included.\nResults are sorted by lastModifiedAt in descending order, then mapped to API response objects.\n",
        "operationId": "getAllBlogs",
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "description": "Substring to match against blog slugs",
            "required": false,
            "schema": {
              "type": "string"
            },
            "example": "spring-boot"
          },
          {
            "name": "status",
            "in": "query",
            "description": "Filter by blog status",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["PUBLISHED", "UNPUBLISHED"]
            },
            "example": "PUBLISHED"
          },
          {
            "name": "X-API-Version",
            "in": "header",
            "schema": {
              "type": "string",
              "default": "1.0.0",
              "enum": ["1"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Blogs retrieved",
            "content": {
              "*/*": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/BlogResponse"
                  }
                },
                "examples": {
                  "blogList": {
                    "description": "blogList",
                    "value": [
                      {
                        "slug": "my-first-blog",
                        "title": "My First Blog",
                        "description": "Short description for the blog",
                        "status": "PUBLISHED",
                        "postedAt": "2026-04-08T12:00:00.000+00:00",
                        "lastModifiedAt": "2026-04-08T12:00:00.000+00:00",
                        "topics": ["spring", "api"],
                        "faqs": [
                          {
                            "question": "What is this?",
                            "answer": "A demo blog."
                          }
                        ],
                        "content": "## Hello world"
                      }
                    ]
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ExceptionResponse"
                },
                "examples": {
                  "validationError": {
                    "description": "validationError",
                    "value": {
                      "message": "Invalid request"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ExceptionResponse"
                },
                "examples": {
                  "unauthorized": {
                    "description": "unauthorized",
                    "value": {
                      "message": "Invalid username or password provided"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ExceptionResponse"
                },
                "examples": {
                  "notFound": {
                    "description": "notFound",
                    "value": {
                      "message": "Slug not found!"
                    }
                  }
                }
              }
            }
          },
          "409": {
            "description": "Conflict",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ExceptionResponse"
                },
                "examples": {
                  "conflict": {
                    "description": "conflict",
                    "value": {
                      "message": "Slug already exists in the database"
                    }
                  }
                }
              }
            }
          }
        }
